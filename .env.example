# PostgreSQL
POSTGRES_USER=hhparser
POSTGRES_PASSWORD=hhparser_password
POSTGRES_DB=hhparser_db
POSTGRES_HOST=postgresql
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# RabbitMQ
RABBITMQ_USER=hhparser
RABBITMQ_PASSWORD=hhparser_password
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672

# API Gateway
API_SECRET_KEY=your-super-secret-key-change-it
API_HOST=0.0.0.0
API_PORT=8000
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# HH.ru API
HH_API_BASE_URL=https://api.hh.ru
HH_USER_AGENT=HH-Parser/1.0

# GigaChat
GIGACHAT_CLIENT_ID=your-gigachat-client-id
GIGACHAT_CLIENT_SECRET=your-gigachat-client-secret
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Parser
PARSER_INTERVAL_SECONDS=3600 #300 секунд для тестов

# Environment
ENVIRONMENT=development
DEBUG=true